{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rift.local/schemas/entryway.schema.json",
  "title": "Rift Entryway Map",
  "description": "Output of /entryways mode. Adjacent probe surface for a given root finding.",
  "type": "object",
  "required": ["case_id", "root_failure", "entryways"],
  "properties": {
    "case_id": { "type": "string" },
    "root_failure": {
      "type": "string",
      "description": "Slug of the hypothesis-family card the case anchors to."
    },
    "adjacent_failures": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Other hypothesis-family slugs the root may shade into."
    },
    "entryways": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "research_question", "safe_observation_goal"],
        "properties": {
          "name": { "type": "string" },
          "research_question": {
            "type": "string",
            "description": "The single question this entryway answers, in researcher's words."
          },
          "why_it_matters": { "type": "string" },
          "safe_observation_goal": {
            "type": "string",
            "description": "What observation is sufficient to call success — without escalating beyond authorized scope."
          },
          "severity_upgrade_if": {
            "type": "array",
            "items": { "type": "string" }
          },
          "likely_mitigation": { "type": "string" },
          "evidence_to_collect": {
            "type": "array",
            "items": { "type": "string" }
          },
          "dead_end_if": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Conditions that prove this entryway is not productive — stop testing."
          },
          "triage_pushback": {
            "type": "array",
            "items": { "type": "string" }
          },
          "rebuttal": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    },
    "do_not_overclaim": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Claims that look like wins but should not appear in the final report."
    }
  },
  "additionalProperties": false
}
